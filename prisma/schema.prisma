generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Platform {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("notstarted")
  assignee  String   @default("Krutik")
  date      String
  url       String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
